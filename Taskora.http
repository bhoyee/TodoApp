@TodoApp_HostAddress = http://localhost:5080
@projectId = 10000000-0000-0000-0000-000000000001
@taskId = 20000000-0000-0000-0000-000000000002
@workspaceId = 40000000-0000-0000-0000-000000000001
@ownerId = 30000000-0000-0000-0000-000000000001

GET {{TodoApp_HostAddress}}/health/live
Accept: application/json

###

GET {{TodoApp_HostAddress}}/health/ready
Accept: application/json

###

GET {{TodoApp_HostAddress}}/openapi/v1.json
Accept: application/json

###

POST {{TodoApp_HostAddress}}/api/v1/projects
Content-Type: application/json
X-Correlation-ID: vscode-create-project

{
  "name": "Portfolio API",
  "description": "Created from the VS Code HTTP client",
  "targetDate": "2026-08-01"
}

###

GET {{TodoApp_HostAddress}}/api/v1/projects/{{projectId}}
Accept: application/json

###

GET {{TodoApp_HostAddress}}/api/v1/projects/{{projectId}}/board
Accept: application/json

###

POST {{TodoApp_HostAddress}}/api/v1/projects/{{projectId}}/tasks
Content-Type: application/json

{
  "title": "Exercise the production API",
  "dueDate": "2026-07-15",
  "effort": 3
}

###

GET {{TodoApp_HostAddress}}/api/v1/tasks?projectId={{projectId}}&pageNumber=1&pageSize=20
Accept: application/json

###

GET {{TodoApp_HostAddress}}/api/v1/tasks/{{taskId}}
Accept: application/json

###

GET {{TodoApp_HostAddress}}/api/v1/tasks/{{taskId}}/activity
Accept: application/json

###

GET {{TodoApp_HostAddress}}/api/v1/dashboard
Accept: application/json
X-User-Id: {{ownerId}}

###

GET {{TodoApp_HostAddress}}/api/v1/workspaces
Accept: application/json
X-User-Id: {{ownerId}}

###

GET {{TodoApp_HostAddress}}/api/v1/workspaces/{{workspaceId}}/members
Accept: application/json
X-User-Id: {{ownerId}}

###

POST {{TodoApp_HostAddress}}/api/v1/tasks/{{taskId}}/ready
X-Correlation-ID: vscode-task-workflow

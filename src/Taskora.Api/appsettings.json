{
  "ConnectionStrings": {
    "TodoApp": "Data Source=todoapp.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "EnsureCreatedOnStartup": false,
    "ApplyMigrationsOnStartup": false
  },
  "DemoData": {
    "SeedOnStartup": false
  },
  "Operations": {
    "Logs": {
      "RetentionDays": 30,
      "MaxEntries": 200
    },
    "Backups": {
      "Enabled": true,
      "Directory": "App_Data/backups",
      "RetentionDays": 7,
      "IntervalHours": 24,
      "RunOnStartup": true
    }
  },
  "Notifications": {
    "Scheduler": {
      "Enabled": true,
      "IntervalMinutes": 1440
    }
  },
  "Authentication": {
    "Mode": "AppToken",
    "Authority": "",
    "Audience": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Administration": {
    "SuperAdminEmails": []
  },
  "App": {
    "PublicBaseUrl": "http://localhost:5173",
    "TimeZoneId": "Europe/London"
  },
  "Email": {
    "Smtp": {
      "Enabled": false,
      "Host": "",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "",
      "FromName": "Taskora"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
